{
  "manifest_version": 3,
  "name": "Homepage New Tab",
  "version": "1.1",
  "description": "Opens homepage.romaine.life and selected homepage links in Chrome tabs",
  "homepage_url": "https://homepage.romaine.life",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs"],
  "host_permissions": ["https://homepage.romaine.life/*"],
  "commands": {
    "open-homepage": {
      "suggested_key": {
        "default": "Ctrl+Shift+H"
      },
      "description": "Open homepage in a new tab"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://homepage.romaine.life/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
